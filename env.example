# Docker / Postgres
POSTGRES_DB=paramext
POSTGRES_USER=paramext
POSTGRES_PASSWORD=change_me_postgres

# Backend runtime
APP_ENV=production
DATABASE_MIN_CONNECTIONS=4
DATABASE_MAX_CONNECTIONS=40
DATABASE_REPAIR_INTERVAL_SECONDS=300

# Optional public Bearer token for extension requests (master token).
# Per-user tokens from the Telegram bot work alongside this.
# If empty AND no user tokens exist, endpoints are open.
API_BEARER_TOKEN=
API_TOKEN=change_me_api_token

# Default extension API settings (used to prefill popup fields)
MOODLE_API_BASE_URL=https://syncshare.naloaty.me/api
MOODLE_API_TOKEN=
MOODLE_API_TIMEOUT_MS=4000
OPENEDU_API_BASE_URL=https://paramext.ruka.me/api
OPENEDU_API_TOKEN=
OPENEDU_API_TIMEOUT_MS=4000

# Admin dashboard. ADMIN_TOKEN is the password used on /admin/login.
ADMIN_TOKEN=change_me_admin_password
ADMIN_SECRET_KEY=change_me_long_random_secret

# Telegram bot (used for user registration AND error forwarding)
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_TOPIC_ID=0
TELEGRAM_PROXY_URL=http://127.0.0.1:8080

# Link to the Telegram bot shown in extension popup
BOT_LINK=https://t.me/moodush_bot

# Public extension build defaults (GitHub Actions -> js/build_config.js)
REPOSITORY_URL=https://github.com/KOSFin/MooDuSh-from-syncshare
UPDATE_CHECK_URL=
BUILD_CHANNEL=local
BUILD_ID=local-dev
OPENEDU_PARSER_VERSION=openedu-parser-v2.0.0
RELEASE_PUBLIC_KEY=

# Backend V2 release/update and abuse controls
EXTENSION_LATEST_VERSION=2.9.6
EXTENSION_REQUIRED_VERSION=
EXTENSION_RELEASE_URL=
EXTENSION_REPOSITORY_URL=https://github.com/KOSFin/MooDuSh-from-syncshare
EXTENSION_KNOWN_BUILD_IDS=
OPENEDU_KNOWN_PARSER_VERSIONS=openedu-parser-v2.0.0
V2_RATE_LIMIT_PER_MINUTE=120
